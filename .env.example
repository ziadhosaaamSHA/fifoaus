# Server
PORT=3000
BASE_URL=http://localhost:3000
SUCCESS_URL=http://localhost:3000/success
CANCEL_URL=http://localhost:3000/cancel

# If SUCCESS_URL/CANCEL_URL are omitted, the server derives them from:
# BASE_URL (if set) or the incoming request host.

# Support (optional, shown on success/fail pages)
SUPPORT_TEXT="Contact support in #support"

# Stripe
STRIPE_SECRET=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Discord
DISCORD_TOKEN=...
DISCORD_GUILD_ID=...
DISCORD_PREMIUM_ROLE_ID=...

# Optional: subscriber counter voice channel id
DISCORD_SUBSCRIBER_VOICE_CHANNEL_ID=

# SEEK FIFO scraper
SEEK_FIFO_ENABLED=false
SEEK_FIFO_CHANNEL_ID=
SEEK_FIFO_SEARCH_URL=https://au.seek.com/FIFO-jobs
SEEK_FIFO_CRON=0 * * * *
SEEK_FIFO_MAX_RESULTS=10
