# Server
PORT=3000
BASE_URL=http://localhost:3000
SUCCESS_URL=http://localhost:3000/success
CANCEL_URL=http://localhost:3000/cancel

# On Railway you can omit SUCCESS_URL/CANCEL_URL and they will default to:
# https://$RAILWAY_PUBLIC_DOMAIN/success and https://$RAILWAY_PUBLIC_DOMAIN/cancel

# Stripe
STRIPE_SECRET=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Discord
DISCORD_TOKEN=...
DISCORD_GUILD_ID=...
DISCORD_PREMIUM_ROLE_ID=...

# Optional: subscriber counter voice channel id
DISCORD_SUBSCRIBER_VOICE_CHANNEL_ID=
