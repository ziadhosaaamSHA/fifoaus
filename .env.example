# Server
PORT=3000
BASE_URL=http://localhost:3000
SUCCESS_URL=http://localhost:3000/success
CANCEL_URL=http://localhost:3000/cancel

# If SUCCESS_URL/CANCEL_URL are omitted, the server derives them from:
# BASE_URL (if set) or the incoming request host.

# Support (optional, shown on success/fail pages)
SUPPORT_TEXT="Contact support in #support"

# Required for job commands/watchers: URL of the separate content-api Railway service.
# Set CONTENT_API_TOKEN on both services to protect /api routes.
CONTENT_API_BASE_URL=
CONTENT_API_TOKEN=

# Stripe
STRIPE_SECRET=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Discord
DISCORD_TOKEN=...
DISCORD_GUILD_ID=...
DISCORD_PREMIUM_ROLE_ID=...

# Optional: subscriber counter voice channel id
DISCORD_SUBSCRIBER_VOICE_CHANNEL_ID=

# Content destination channels
FIFO_JOBS_CHANNEL_ID=
NEWS_CHANNEL_ID=

# SEEK FIFO scraper
SEEK_FIFO_ENABLED=false
SEEK_FIFO_CRON=0 * * * *
SEEK_FIFO_MAX_RESULTS=10

# LinkedIn FIFO scraper
LINKEDIN_FIFO_ENABLED=false
LINKEDIN_FIFO_CRON=7 * * * *
LINKEDIN_FIFO_MAX_RESULTS=10

# Mining/news feed consumer
NEWS_ENABLED=false
NEWS_CRON=*/15 * * * *
NEWS_MAX_RESULTS=5
NEWS_SOURCE=australian-mining-review,australian-mining,industry-qld,paydirt,mining-technology
